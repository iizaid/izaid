generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?
  name      String?
  avatarUrl String?
  phone     String?
  location  String?
  bio       String?
  role      Role     @default(USER)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

model Client {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  source    String?  // Where did they come from (WhatsApp, Discord, etc)
  
  orders    Order[]
  payments  Payment[]
  brandKit  BrandKit?
  deliverables Deliverable[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BrandKit {
  id        String   @id @default(uuid())
  clientId  String   @unique
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  colors    String[] 
  fonts     String[] 
  styleTags String[] 
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Deliverable {
  id        String   @id @default(uuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  title     String   
  imageUrl  String   
  
  createdAt DateTime @default(now())
}

model Order {
  id          String   @id @default(uuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  planType    String   // e.g., 'standard', 'professional', 'starter_monthly'
  isMonthly   Boolean  @default(false)
  
  totalAmount Float
  paidAmount  Float    @default(0)
  
  status      String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, CANCELLED
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Payment {
  id          String   @id @default(uuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  amount      Float
  date        DateTime @default(now())
  method      String?  // PayPal, Bank, Cash, etc.
  
  createdAt   DateTime @default(now())
}

model Lead {
  id          String   @id @default(uuid())
  name        String
  email       String?
  phone       String?
  notes       String?
  source      String?  // YouTube, Discord, Instagram, etc.
  status      LeadStatus @default(NEW)
  logo        String?  @db.Text  // base64 encoded channel logo
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  NOT_INTERESTED
  CONVERTED
}

model ShowcaseImage {
  id           String   @id @default(uuid())
  image        String?  @db.Text
  imageBase64  String   @default("") @db.Text
  mimeType     String   @default("image/webp")
  originalName String?
  altText      String?
  order        Int      @default(0)
  isPublished  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
